// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Certificate {
  id            String   @id @default(uuid())
  certificateId String   @unique
  name          String
  eventName     String
  issueDate     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model IssuerProfile {
  id          String @id @default("singleton")
  name        String @default("CertifyEasy Official")
  website     String @default("https://certifyeasy.com")
  email       String @default("verify@certifyeasy.com")
  address     String @default("123 Tech Avenue, Silicon Valley, CA")
  description String @default("A global leader in secure digital credentialing and verification services.")
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  userAgent String?
  createdAt DateTime @default(now())
}

model VerificationLog {
  id            String   @id @default(uuid())
  certificateId String
  success       Boolean
  createdAt     DateTime @default(now())
}
